    public class Learner
    {
        string firstName; 
        string lastName;
        int[,] grades; 
        double[] averageGrades;
        
        public int[,] Grades => (int[,])grades.Clone();
        
        public double[] AverageGrades
        {
            get
            {
                if (grades == null || grades.GetLength(0) == 0 || grades.GetLength(1) == 0) 
                    return null;
                    
                var averages = new double[grades.GetLength(0)];
                for (int row = 0; row < averages.Length; row++)
                {
                    for (int col = 0; col < grades.GetLength(1); col++)
                    {
                        averages[row] += (double)grades[row, col] / grades.GetLength(1);
                    }
                }
                return averages;
            }
        }
        
        public char this[int index]
        { 
            get { return firstName[index]; } 
        }
        
        public double this[int row, int col]
        {
            get { return grades[row, col]; }
            set
            {
                if (value >= 2 && value <= 5) 
                    grades[row, col] = (int)value;
            }
        }
        
        public Learner(string name, string surname, int[,] marks = null)
        {
            firstName = name; 
            lastName = surname;
            if (marks != null)
            { 
                grades = (int[,])marks.Clone(); 
            }
        }
        
        public override string ToString()
        {
            var result = firstName + " " + lastName;
            for (int i = 0; i < grades.GetLength(0); i++)
            {
                for (int j = 0; j < grades.GetLength(1); j++)
                {
                    result += grades[i, j] + " ";
                }
                result = result.TrimEnd();
                result += Environment.NewLine;
            }
            return result;
            
            StringBuilder sb = new StringBuilder(firstName);
            sb.Append("...");
            sb.AppendLine(lastName);
            for (int i = 0; i < grades.GetLength(0); i++)
            {
                for (int j = 0; j < grades.GetLength(1); j++)
                {
                    sb.Append(grades[i, j]).Append(" ");
                }
                result = result.TrimEnd();
                result += Environment.NewLine;
            }
        }
    }
